  },
  "devDependencies": {
    "prisma": "^5.12.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2",
    "@types/express": "^4.17.19",
    "@types/node": "^20.4.2"
  }
}
